<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121216">

    <!-- BARRE SUPÉRIEURE EN TÊTE (PRO) -->
    <LinearLayout
        android:id="@+id/top_menu_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:background="#1C1C24"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/menu_file"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="≡ Fichier"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/menu_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Édition"
            android:textColor="#A0A0B0"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/menu_layers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Calques"
            android:textColor="#A0A0B0"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btn_fullscreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#2B2B38"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp"
            android:text="⛶ Plein Écran"
            android:textColor="#00E676"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ZONE DE DESSIN CENTRAL -->
    <com.virtix.nastapaint.ui.views.MangaCanvasView
        android:id="@+id/mangaCanvasView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_status_bar"
        android:layout_below="@id/top_menu_bar" />

    <!-- DOCK D'OUTILS PRINCIPAL (FLOTTANT EN BAS) -->
    <LinearLayout
        android:id="@+id/dock_tools"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_above="@id/bottom_status_bar"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="12dp"
        android:background="#CC1C1C24"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/btn_tool_pen"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="✏️"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btn_tool_eraser"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="🧹"
            android:textSize="18sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="#333344" />

        <TextView
            android:id="@+id/btn_tool_undo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="↩️"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/btn_tool_redo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="↪️"
            android:textSize="16sp" />

        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:background="#333344" />

        <TextView
            android:id="@+id/btn_tool_clear"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="🗑️"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- BARRE DE STATUT (BAS) -->
    <LinearLayout
        android:id="@+id/bottom_status_bar"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_alignParentBottom="true"
        android:background="#181820"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/txt_brush_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plume G • 8px"
            android:textColor="#8888A0"
            android:textSize="11sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/txt_canvas_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Planche Vabeir Studio"
            android:textColor="#8888A0"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- BOUTON DU MODE IMMERSIF -->
    <TextView
        android:id="@+id/btn_restore_ui"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="12dp"
        android:background="#E61C1C24"
        android:padding="10dp"
        android:text="👁 Afficher UI"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

</RelativeLayout>
