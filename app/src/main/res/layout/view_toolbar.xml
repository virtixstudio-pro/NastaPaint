<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="#141419"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <ImageButton android:id="@+id/btn_pen" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_edit" />
    <ImageButton android:id="@+id/btn_eraser" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" />
    <ImageButton android:id="@+id/btn_clear" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_close_clear_cancel" />
    
    <ImageButton android:id="@+id/btn_size_minus" android:layout_width="32dp" android:layout_height="32dp" android:text="-" />
    <TextView android:id="@+id/txt_size" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15" android:textColor="#FFFFFF" />
    <ImageButton android:id="@+id/btn_size_plus" android:layout_width="32dp" android:layout_height="32dp" android:text="+" />

    <ImageButton android:id="@+id/btn_undo" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_revert" />
    <ImageButton android:id="@+id/btn_redo" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_forward" />
    <ImageButton android:id="@+id/btn_import" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_gallery" />
    <ImageButton android:id="@+id/btn_layers" android:layout_width="36dp" android:layout_height="36dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_slideshow" />
</LinearLayout>
